def run_command(name, args=None):
    """Invoke a registered command or action by name. Used by sequences and @-refs."""
    if args is None:
        args = []
    if name in _actions:
        _actions[name](args)
        return
    cmds = _all_commands()
    if name not in cmds:
        err(f"run_command: unknown action or command '{name}'")
        sys.exit(1)
    cmds[name]["func"](args)


