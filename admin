# boot() — single entry point

def boot(project_name, load_dotenv=True):
    """Entry point for per-project admin files.

    Call this from __main__. Handles chdir, argv parsing, TUI or dispatch.
    """
    # Determine project root from the caller's __file__ (the admin script)
    import inspect
    caller_frame = inspect.stack()[1]
    admin_file = caller_frame.filename
    project_root = os.path.dirname(os.path.abspath(admin_file))

    os.chdir(project_root)
    _init(project_name, project_root)
    _apply_log_config()

    _load_dotenv(project_root)
    _resolve_pending_urls()

    if len(sys.argv) < 2:
        _tui_menu()
        return

    cmd_name = sys.argv[1]
    if cmd_name in ("-h", "--help", "help"):
        _print_help()
        return

    if cmd_name == "env":
        cmd_env(sys.argv[2:])
        return

    if cmd_name in ("regenerate", "regen"):
        admin_gen = os.path.expanduser("~/.admin/admin-gen")
        if not os.path.isfile(admin_gen):
            admin_gen_fallback = os.path.expanduser("~/.admin/init-admin")
            if os.path.isfile(admin_gen_fallback):
                warn("admin-gen not found — falling back to init-admin (reinstall admin-project-tool to upgrade)")
                admin_gen = admin_gen_fallback
            else:
                err("admin-gen not found at ~/.admin/ — is admin-project-tool installed?")
                sys.exit(1)
        sys.exit(subprocess.call([admin_gen, "--regenerate", _project_root] + sys.argv[2:]))

    all_cmds = _all_commands()
    if cmd_name not in all_cmds:
        err(f"Unknown command: {cmd_name}")
        _print_help()
        sys.exit(1)

    args = sys.argv[2:]

    # Check for subcommand help
    if ("-h" in args or "--help" in args) and cmd_name in _subcommand_help:
        _subcommand_help[cmd_name]()
        return

    all_cmds[cmd_name]["func"](args)
    _announce_log_end()


# Built-in logs command

def _cmd_logs_impl(args):
    """Tail a log file from tmp/. Args act as a substring filter on filenames."""
    import glob
    import datetime

    log_dir = LOG_DIR or os.path.join(os.getcwd(), "tmp")
    filter_str = "-".join(args).lower()
    if filter_str.endswith(".log"):
        filter_str = filter_str[:-4]

    all_logs = sorted(
        glob.glob(os.path.join(log_dir, "*.log")),
        key=os.path.getmtime,
        reverse=True,
    )

    matches = all_logs
    if filter_str:
        filtered = [f for f in all_logs if filter_str in os.path.basename(f)[:-4].lower()]
        if filtered:
            matches = filtered

    if not matches:
        err(f"no log files found in {log_dir}")
        return

    if len(matches) == 1:
        chosen = matches[0]
    else:
        menu = OrderedDict()
        for f in matches:
            name = os.path.basename(f)
            try:
                size = os.path.getsize(f)
                age = datetime.datetime.fromtimestamp(os.path.getmtime(f)).strftime("%m/%d %H:%M")
                label = f"{name}  ({size:,}b, {age})"
            except OSError:
                label = name
            menu[name] = label
        picked = pick_target(menu, "tail which log?")
        if not picked:
            return
        chosen = os.path.join(log_dir, picked)

    info(f"tailing {os.path.relpath(chosen)}")
    subprocess.call(["tail", "-f", "-n", "100", chosen])


def register_builtin_logs_command():
    """Register the universal logs file-tailer. Called by generated admin scripts."""
    @command("logs", "Tail a command's log file (./admin logs [filter...])")
    def cmd_logs(args):
        _cmd_logs_impl(args)

