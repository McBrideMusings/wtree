#!/usr/bin/env bash
# wtree — git worktree helper
# Manages worktrees under .worktrees/ with optional GitHub issue integration.

cmd="${1:-}"

_wtree_sanitize() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr -s ' /:'"'"'".,' '-' | tr -cd '[:alnum:]-' | sed 's/--*/-/g; s/^-//; s/-$//'
}

_wtree_copy_configs() {
  local repo_root="$1" worktree_path="$2"
  find "$repo_root" -maxdepth 1 -name '.env*' -exec cp {} "$worktree_path/" \;
  if [ -f "$repo_root/.claude/settings.local.json" ]; then
    mkdir -p "$worktree_path/.claude"
    cp "$repo_root/.claude/settings.local.json" "$worktree_path/.claude/"
  fi
}

_wtree_install_deps() {
  local worktree_path="$1"
  if [ -f "$worktree_path/bun.lockb" ] || [ -f "$worktree_path/bun.lock" ]; then
    echo "Installing dependencies with bun..."
    (cd "$worktree_path" && bun install)
  elif [ -f "$worktree_path/package-lock.json" ]; then
    echo "Installing dependencies with npm..."
    (cd "$worktree_path" && npm install)
  elif [ -f "$worktree_path/yarn.lock" ]; then
    echo "Installing dependencies with yarn..."
    (cd "$worktree_path" && yarn install)
  elif [ -f "$worktree_path/pnpm-lock.yaml" ]; then
    echo "Installing dependencies with pnpm..."
    (cd "$worktree_path" && pnpm install)
  fi
}

_wtree_is_own_repo() {
  local remote_url
  remote_url=$(git remote get-url origin 2>/dev/null) || return 0
  [[ "$remote_url" == *"McBrideMusings"* ]]
}

_wtree_ensure_gitignore() {
  local repo_root="$1"
  if ! grep -qxF '.worktrees' "$repo_root/.gitignore" 2>/dev/null; then
    echo '.worktrees' >> "$repo_root/.gitignore"
    echo "Added .worktrees to .gitignore"
  fi
}

# Get owner/repo from current repo's origin remote
_wtree_get_nwo() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || return 1
  url="${url%.git}"
  if [[ "$url" == git@github.com:* ]]; then
    echo "${url#git@github.com:}"
  elif [[ "$url" == https://github.com/* ]]; then
    echo "${url#https://github.com/}"
  else
    return 1
  fi
}

# Get main repo root (works from inside a worktree or from main)
_wtree_repo_root() {
  local repo_root
  repo_root="$(git rev-parse --show-toplevel)" || return 1
  local _gd _cd2
  _gd="$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)"
  _cd2="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
  if [[ "$_gd" != "$_cd2" ]]; then
    repo_root="${_cd2%/*}"
  fi
  echo "$repo_root"
}

# Check if a worktree already exists for a given branch
# Sets _wt_existing_path if found
_wtree_find_existing() {
  local target_branch="$1"
  local repo_root
  repo_root=$(_wtree_repo_root) || return 1
  _wt_existing_path=""
  while IFS= read -r _line; do
    local _path="${_line%% *}"
    [[ "$_path" == "$repo_root" ]] && continue
    local _branch="${_line##*\[}"
    _branch="${_branch%\]*}"
    if [[ "$_branch" == "$target_branch" ]]; then
      _wt_existing_path="$_path"
      return 0
    fi
  done < <(git worktree list)
  return 1
}

# Remove a worktree by name or full path
_wtree_do_remove() {
  local target="$1"
  local force_flag="${2:---no-force}"

  if [[ "$target" != */* ]]; then
    local repo_root
    repo_root=$(_wtree_repo_root) || return 1
    target="$repo_root/.worktrees/$target"
  fi

  if [[ "$(pwd)" == "$target"* ]]; then
    local main_root
    main_root="$(git -C "$target" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
    main_root="${main_root%/*}"
    echo "Changing directory to $main_root"
    cd "$main_root"
  fi

  echo "Removing worktree: $target"
  if [[ "$force_flag" == "--force" ]]; then
    git worktree remove --force "$target" && echo "Done." || return 1
  else
    git worktree remove "$target" 2>&1 && echo "Done." || {
      echo ""
      printf "Removal failed. Force remove? [y/N] "
      local _confirm=""
      while [[ -z "$_confirm" || "$_confirm" == $'\n' || "$_confirm" == $'\r' ]]; do
        read -rsk1 _confirm
      done
      echo ""
      if [[ "$_confirm" == [yY] ]]; then
        git worktree remove --force "$target" && echo "Done." || return 1
      else
        return 1
      fi
    }
  fi
}

# Interactive worktree picker
# Args: prompt_text [default_action]
# Sets: _wt_picked_name _wt_picked_action
_wtree_picker() {
  local prompt_text="$1"
  local default_action="${2:-enter}"
  local repo_root
  repo_root=$(_wtree_repo_root) || return 1

  local -a _wt_names=() _wt_lines=()
  while IFS= read -r _line; do
    local _path="${_line%% *}"
    local _name="${_path##*/}"
    [[ "$_path" == "$repo_root" ]] && continue
    _wt_names+=("$_name")
    _wt_lines+=("$_line")
  done < <(git worktree list)

  if [[ ${#_wt_names[@]} -eq 0 ]]; then
    echo "No worktrees. Use 'wtree add <input>' to create one."
    return 1
  fi

  local _sel=0 _total=${#_wt_names[@]} _key
  local -a _wt_display=()
  for (( _i=0; _i<_total; _i++ )); do
    local _full="${_wt_lines[$((_i+1))]}"
    local _branch="${_full##*\[}"
    _branch="${_branch%\]*}"
    _wt_display+=("${_wt_names[$((_i+1))]}  (${_branch})")
  done

  local _term_width="${COLUMNS:-80}"

  _wtree_draw_menu() {
    local i _line_text
    for (( i=0; i<_total; i++ )); do
      if (( i == _sel )); then
        _line_text="  ▸ ${_wt_display[$((i+1))]}"
        printf "\033[7m%-*.*s\033[0m\n" "$_term_width" "$_term_width" "$_line_text"
      else
        _line_text="    ${_wt_display[$((i+1))]}"
        printf "%.*s\n" "$_term_width" "$_line_text"
      fi
    done
  }

  _wtree_clear_menu() {
    printf "\033[%dA\033[J" "$_total"
  }

  echo "$prompt_text"
  _wtree_draw_menu
  _wt_picked_action=""
  _wt_picked_name=""

  while true; do
    read -rsk1 _key
    if [[ "$_key" == $'\e' ]]; then
      read -rsk1 -t 0.01 _key
      if [[ "$_key" == "[" ]]; then
        read -rsk1 -t 0.01 _key
        case "$_key" in
          A) (( _sel > 0 )) && (( _sel-- )) ;;
          B) (( _sel < _total - 1 )) && (( _sel++ )) ;;
        esac
      else
        _wtree_clear_menu
        echo "Cancelled."
        unfunction _wtree_draw_menu _wtree_clear_menu 2>/dev/null
        return 1
      fi
    elif [[ "$_key" == $'\n' ]]; then
      _wt_picked_action="$default_action"
      break
    elif [[ "$_key" == "x" ]]; then
      _wt_picked_action="remove"
      break
    elif [[ "$_key" == "q" ]]; then
      _wtree_clear_menu
      echo "Cancelled."
      unfunction _wtree_draw_menu _wtree_clear_menu 2>/dev/null
      return 1
    elif [[ "$_key" == "j" ]]; then
      (( _sel < _total - 1 )) && (( _sel++ ))
    elif [[ "$_key" == "k" ]]; then
      (( _sel > 0 )) && (( _sel-- ))
    fi
    _wtree_clear_menu
    _wtree_draw_menu
  done

  _wtree_clear_menu
  _wt_picked_name="${_wt_names[$((_sel+1))]}"
  unfunction _wtree_draw_menu _wtree_clear_menu 2>/dev/null
}

_wtree_do_add() {
  local input="$1"
  if [ -z "$input" ]; then
    echo "Usage: wtree <input>" >&2
    echo "  <input> can be: branch name, issue/PR number (#N or N), or GitHub PR/issue URL" >&2
    return 1
  fi

  local repo_root
  repo_root=$(_wtree_repo_root) || return 1

  # Classify input
  local _type="" _num=""
  case "$input" in
    https://github.com/*/pull/[0-9]*)
      _type="pr"
      local _stripped="${input#https://github.com/}"
      local _url_nwo="${_stripped%%/pull/*}"
      local _rest="${_stripped#*/pull/}"
      _num="${_rest%%/*}"
      # Validate repo match
      local _current_nwo
      _current_nwo=$(_wtree_get_nwo) || { echo "Could not determine current repo from origin" >&2; return 1; }
      local _lower_url _lower_current
      _lower_url=$(echo "$_url_nwo" | tr '[:upper:]' '[:lower:]')
      _lower_current=$(echo "$_current_nwo" | tr '[:upper:]' '[:lower:]')
      if [[ "$_lower_url" != "$_lower_current" ]]; then
        echo "Repo mismatch: URL is for $_url_nwo but you're in $_current_nwo" >&2
        return 1
      fi
      ;;
    https://github.com/*/issues/[0-9]*)
      _type="issue"
      local _stripped="${input#https://github.com/}"
      local _url_nwo="${_stripped%%/issues/*}"
      local _rest="${_stripped#*/issues/}"
      _num="${_rest%%/*}"
      # Validate repo match
      local _current_nwo
      _current_nwo=$(_wtree_get_nwo) || { echo "Could not determine current repo from origin" >&2; return 1; }
      local _lower_url _lower_current
      _lower_url=$(echo "$_url_nwo" | tr '[:upper:]' '[:lower:]')
      _lower_current=$(echo "$_current_nwo" | tr '[:upper:]' '[:lower:]')
      if [[ "$_lower_url" != "$_lower_current" ]]; then
        echo "Repo mismatch: URL is for $_url_nwo but you're in $_current_nwo" >&2
        return 1
      fi
      ;;
    *)
      local _stripped_hash="${input#\#}"
      if [[ "$_stripped_hash" =~ ^[0-9]+$ ]]; then
        _type="number"
        _num="$_stripped_hash"
      else
        _type="text"
      fi
      ;;
  esac

  # Resolve to branch, slug, and summary
  local branch="" slug="" summary="" is_existing_branch=false

  case "$_type" in
    pr)
      local _pr_data head_branch pr_title
      _pr_data=$(gh pr view "$_num" --json headRefName,title -q '.headRefName + "\t" + .title') || {
        echo "Failed to fetch PR #$_num" >&2
        return 1
      }
      head_branch="${_pr_data%%	*}"
      pr_title="${_pr_data#*	}"
      branch="$head_branch"
      slug="$(_wtree_sanitize "$head_branch")"
      summary="PR #$_num: $pr_title → branch \"$head_branch\""
      is_existing_branch=true
      ;;
    issue)
      local issue_title
      issue_title=$(gh issue view "$_num" --json title -q .title) || {
        echo "Failed to fetch issue #$_num" >&2
        return 1
      }
      slug="${_num}-$(_wtree_sanitize "$issue_title")"
      summary="Issue #$_num: $issue_title"
      ;;
    number)
      local _pr_data head_branch pr_title
      if _pr_data=$(gh pr view "$_num" --json headRefName,title -q '.headRefName + "\t" + .title' 2>/dev/null); then
        head_branch="${_pr_data%%	*}"
        pr_title="${_pr_data#*	}"
        branch="$head_branch"
        slug="$(_wtree_sanitize "$head_branch")"
        summary="PR #$_num: $pr_title → branch \"$head_branch\""
        is_existing_branch=true
      else
        local issue_title
        issue_title=$(gh issue view "$_num" --json title -q .title) || {
          echo "#$_num is not a PR or issue in this repo" >&2
          return 1
        }
        slug="${_num}-$(_wtree_sanitize "$issue_title")"
        summary="Issue #$_num: $issue_title"
      fi
      ;;
    text)
      if git show-ref --verify --quiet "refs/heads/$input" 2>/dev/null; then
        branch="$input"
        slug="$(_wtree_sanitize "$input")"
        summary="Branch \"$input\" (local)"
        is_existing_branch=true
      elif git show-ref --verify --quiet "refs/remotes/origin/$input" 2>/dev/null; then
        branch="$input"
        slug="$(_wtree_sanitize "$input")"
        summary="Branch \"$input\" (remote)"
        is_existing_branch=true
      else
        slug="$(_wtree_sanitize "$input")"
        summary="New branch from \"$input\""
      fi
      ;;
  esac

  # Determine branch name if not already set (issue / new branch cases)
  if [ -z "$branch" ]; then
    if _wtree_is_own_repo; then
      branch="$slug"
    elif [[ "$_type" == "text" && "$input" == */* ]]; then
      branch="$input"
    else
      branch="pierce/$slug"
    fi
  fi

  # Check for existing worktree with this branch
  if _wtree_find_existing "$branch"; then
    echo "Worktree already exists for branch \"$branch\": $_wt_existing_path"
    printf "cd into it? (enter: yes · esc: no) "
    local _ans
    read -rsk1 _ans
    echo ""
    if [[ "$_ans" == $'\n' || "$_ans" == "" || "$_ans" == [yY] ]]; then
      cd "$_wt_existing_path"
      echo "Now in: $(pwd)"
      return 0
    fi
    return 1
  fi

  # Confirm
  local worktree_path="$repo_root/.worktrees/$slug"
  echo ""
  echo "  Detected: $summary"
  echo "  Worktree: .worktrees/$slug"
  echo "  Branch:   $branch"
  echo ""
  printf "Continue? (enter: yes · esc: no) "
  local _ans
  read -rsk1 _ans
  echo ""
  if [[ "$_ans" != $'\n' && "$_ans" != "" && "$_ans" != [yY] ]]; then
    echo "Cancelled."
    return 1
  fi

  # Create worktree
  _wtree_ensure_gitignore "$repo_root"
  mkdir -p "$repo_root/.worktrees"

  if [ "$is_existing_branch" = true ]; then
    if ! git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
      git fetch origin "$branch" || { echo "Failed to fetch branch \"$branch\" from origin" >&2; return 1; }
    fi
    git worktree add "$worktree_path" "$branch" || return 1
  else
    git worktree add -b "$branch" "$worktree_path" || return 1
  fi

  _wtree_copy_configs "$repo_root" "$worktree_path"
  _wtree_install_deps "$worktree_path"

  echo ""
  echo "Worktree: $worktree_path"
  echo "Branch:   $branch"
  echo ""

  printf "cd into it? (enter: yes · esc: no) "
  local _cd_ans
  read -rsk1 _cd_ans
  echo ""
  if [[ "$_cd_ans" == $'\n' || "$_cd_ans" == "" || "$_cd_ans" == [yY] ]]; then
    cd "$worktree_path"
  fi
}

case "$cmd" in
  "")
    # Interactive picker — cd or remove
    _wtree_picker "Worktrees (↑/↓ navigate · enter: cd · x: remove · q: quit):" "enter" || return $?
    local _repo_root
    _repo_root=$(_wtree_repo_root) || return 1
    local picked_path="$_repo_root/.worktrees/$_wt_picked_name"

    case "$_wt_picked_action" in
      enter)
        cd "$picked_path"
        echo "Now in: $(pwd)"
        ;;
      remove)
        _wtree_do_remove "$_wt_picked_name"
        ;;
    esac
    ;;

  add)
    shift
    _wtree_do_add "$1"
    ;;

  ls|list)
    git worktree list
    ;;

  rm|remove)
    shift
    local target="" force_flag="--no-force"
    for arg in "$@"; do
      case "$arg" in
        --force) force_flag="--force" ;;
        *) [ -z "$target" ] && target="$arg" ;;
      esac
    done

    if [ -z "$target" ]; then
      local _gitdir _commondir
      _gitdir="$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)"
      _commondir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
      if [[ "$_gitdir" != "$_commondir" ]]; then
        target="$(git rev-parse --show-toplevel 2>/dev/null)"
        echo "Detected worktree: $target"
      else
        _wtree_picker "Select worktree to remove (↑/↓ navigate, enter confirm, q cancel):" "remove" || return $?
        target="$_wt_picked_name"
      fi
    fi

    _wtree_do_remove "$target" "$force_flag"
    ;;

  help)
    echo "Usage: wtree [command] [args]"
    echo ""
    echo "Commands:"
    echo "  (no args)                 Interactive worktree picker (cd/remove)"
    echo "  <input>                   Smart-add worktree from any input:"
    echo "    PR URL                    https://github.com/owner/repo/pull/123"
    echo "    Issue URL                 https://github.com/owner/repo/issues/45"
    echo "    Issue/PR number           42 or #42"
    echo "    Branch name               feature/foo or pierce/my-branch"
    echo "    New name                  my-feature (creates new branch)"
    echo "  add <input>               Same as above (explicit form)"
    echo "  ls                        List all worktrees"
    echo "  rm [name] [--force]       Remove worktree (auto-detects or picker)"
    echo "  help                      Show this help"
    echo ""
    echo "Branches prefixed with pierce/ for repos not owned by McBrideMusings."
    ;;

  *)
    _wtree_do_add "$cmd"
    ;;
esac
