#!/usr/bin/env bash
# wtree — git worktree helper
# Manages worktrees under .worktrees/ with optional GitHub issue integration.

cmd="${1:-}"

_wtree_sanitize() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr -s ' /:'"'"'".,' '-' | tr -cd '[:alnum:]-' | sed 's/--*/-/g; s/^-//; s/-$//'
}

_wtree_trim_slug() {
  local slug="$1"
  local max_len="${2:-36}"

  if [ "${#slug}" -le "$max_len" ]; then
    echo "$slug"
    return 0
  fi

  slug="${slug[1,$max_len]}"
  slug="${slug%-*}"
  if [ -z "$slug" ]; then
    slug="${1[1,$max_len]}"
  fi

  echo "${slug%-}"
}

_wtree_issue_slug() {
  local issue_num="$1"
  local issue_title="$2"
  local sanitized compact="" fallback=""
  local max_words="${WTREE_ISSUE_WORD_LIMIT:-4}"
  local max_len="${WTREE_ISSUE_SLUG_MAX_LEN:-36}"
  local -a words=() kept=()
  local i word next_word

  sanitized="$(_wtree_sanitize "$issue_title")"
  [ -z "$sanitized" ] && sanitized="issue"

  IFS='-' read -rA words <<< "$sanitized"
  for (( i=1; i<=${#words[@]}; i++ )); do
    word="${words[$i]}"
    next_word="${words[$((i+1))]:-}"

    case "$word" in
      a|an|and|at|by|for|from|in|into|of|on|or|the|to|with)
        continue
        ;;
      number)
        if [ "$next_word" = "of" ]; then
          kept+=("count")
          ((i++))
          continue
        fi
        ;;
    esac

    kept+=("$word")
    if [ "${#kept[@]}" -ge "$max_words" ]; then
      break
    fi
  done

  if [ "${#kept[@]}" -eq 0 ]; then
    kept=("${words[@]:0:$max_words}")
  fi

  compact="${(j:-:)kept}"
  fallback="$(_wtree_trim_slug "$sanitized" "$max_len")"
  compact="$(_wtree_trim_slug "$compact" "$max_len")"
  [ -z "$compact" ] && compact="$fallback"

  echo "${issue_num}-${compact}"
}

_wtree_copy_configs() {
  local repo_root="$1" worktree_path="$2"
  find "$repo_root" -maxdepth 1 -name '.env*' -exec cp {} "$worktree_path/" \;
  if [ -f "$repo_root/.claude/settings.local.json" ]; then
    mkdir -p "$worktree_path/.claude"
    cp "$repo_root/.claude/settings.local.json" "$worktree_path/.claude/"
  fi
}

_wtree_install_deps() {
  local worktree_path="$1"
  if [ -n "${WTREE_SKIP_INSTALL:-}" ]; then
    echo "Skipping dependency install (WTREE_SKIP_INSTALL set)."
    return 0
  fi
  local -A _dir_tool=()
  local _lockfile _dir _name _new_priority _current_priority

  while IFS= read -r _lockfile; do
    [ -z "$_lockfile" ] && continue
    _dir="${_lockfile%/*}"
    _name="${_lockfile##*/}"
    case "$_name" in
      bun.lockb|bun.lock) _new_priority=4 ;;
      pnpm-lock.yaml)     _new_priority=3 ;;
      yarn.lock)          _new_priority=2 ;;
      package-lock.json)  _new_priority=1 ;;
      *) continue ;;
    esac
    _current_priority="${_dir_tool[$_dir]%%:*}"
    [ -z "$_current_priority" ] && _current_priority=0
    if (( _new_priority > _current_priority )); then
      case "$_name" in
        bun.lockb|bun.lock) _dir_tool[$_dir]="4:bun" ;;
        pnpm-lock.yaml)     _dir_tool[$_dir]="3:pnpm" ;;
        yarn.lock)          _dir_tool[$_dir]="2:yarn" ;;
        package-lock.json)  _dir_tool[$_dir]="1:npm" ;;
      esac
    fi
  done < <(find "$worktree_path" \
    \( -type d \( -name node_modules -o -name .git -o -name .worktrees -o -name .next -o -name dist -o -name build -o -name target -o -name .venv -o -name venv -o -name .turbo -o -name .cache \) \) -prune \
    -o -type f \( -name bun.lockb -o -name bun.lock -o -name pnpm-lock.yaml -o -name yarn.lock -o -name package-lock.json \) -print 2>/dev/null)

  (( ${#_dir_tool[@]} == 0 )) && return 0

  local _k _tool _rel
  for _k in "${(@ko)_dir_tool}"; do
    _tool="${_dir_tool[$_k]#*:}"
    _rel="${_k#$worktree_path}"
    _rel="${_rel#/}"
    [ -z "$_rel" ] && _rel="."
    echo "Installing dependencies with $_tool in $_rel..."
    (cd "$_k" && "$_tool" install) || echo "  (install failed in $_rel)" >&2
  done
}

# Run a command with a timeout in seconds. Exits 124 if killed.
# Uses perl (guaranteed on macOS) so we don't depend on GNU coreutils `timeout`.
_wtree_sh_timeout() {
  perl -e 'my $t=shift; my $pid=fork(); if(!defined $pid){exit 127} if($pid==0){exec(@ARGV) or exit 127} local $SIG{ALRM}=sub{kill 9,$pid;exit 124}; alarm $t; waitpid $pid,0; exit($?>>8)' "$@"
}

_wtree_is_own_repo() {
  local remote_url
  remote_url=$(git remote get-url origin 2>/dev/null) || return 0
  [[ "$remote_url" == *"McBrideMusings"* ]]
}

_wtree_ensure_gitignore() {
  local repo_root="$1"
  if ! grep -qxF '.worktrees' "$repo_root/.gitignore" 2>/dev/null; then
    echo '.worktrees' >> "$repo_root/.gitignore"
    echo "Added .worktrees to .gitignore"
  fi
}

# Get owner/repo from current repo's origin remote
_wtree_get_nwo() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || return 1
  url="${url%.git}"
  if [[ "$url" == git@github.com:* ]]; then
    echo "${url#git@github.com:}"
  elif [[ "$url" == https://github.com/* ]]; then
    echo "${url#https://github.com/}"
  else
    return 1
  fi
}

# Get main repo root (works from inside a worktree or from main)
_wtree_repo_root() {
  local repo_root
  repo_root="$(git rev-parse --show-toplevel)" || return 1
  local _gd _cd2
  _gd="$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)"
  _cd2="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
  if [[ "$_gd" != "$_cd2" ]]; then
    repo_root="${_cd2%/*}"
  fi
  echo "$repo_root"
}

# Check if a worktree already exists for a given branch
# Sets _wt_existing_path if found
_wtree_find_existing() {
  local target_branch="$1"
  local repo_root
  repo_root=$(_wtree_repo_root) || return 1
  _wt_existing_path=""
  while IFS= read -r _line; do
    local _path="${_line%% *}"
    [[ "$_path" == "$repo_root" ]] && continue
    local _branch="${_line##*\[}"
    _branch="${_branch%\]*}"
    if [[ "$_branch" == "$target_branch" ]]; then
      _wt_existing_path="$_path"
      return 0
    fi
  done < <(git worktree list)
  return 1
}

# Remove a worktree by name or full path
_wtree_do_remove() {
  local target="$1"
  local force_flag="${2:---no-force}"

  if [[ "$target" != */* ]]; then
    local repo_root
    repo_root=$(_wtree_repo_root) || return 1
    target="$repo_root/.worktrees/$target"
  fi

  # Capture the worktree's branch before removal so we can offer to delete it after.
  local _target_branch=""
  while IFS= read -r _line; do
    local _p="${_line%% *}"
    if [[ "$_p" == "$target" ]]; then
      _target_branch="${_line##*\[}"
      _target_branch="${_target_branch%\]*}"
      break
    fi
  done < <(git worktree list)

  if [[ "$(pwd)" == "$target"* ]]; then
    local main_root
    main_root="$(git -C "$target" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
    main_root="${main_root%/*}"
    echo "Changing directory to $main_root"
    cd "$main_root"
  fi

  local _removed=false
  echo "Removing worktree: $target"
  if [[ "$force_flag" == "--force" ]]; then
    git worktree remove --force "$target" && { echo "Done."; _removed=true; } || return 1
  else
    git worktree remove "$target" 2>&1 && { echo "Done."; _removed=true; } || {
      echo ""
      printf "Removal failed. Force remove? (enter: yes · esc: no) "
      local _confirm
      read -rsk1 _confirm
      echo ""
      if [[ "$_confirm" == $'\n' || "$_confirm" == "" || "$_confirm" == [yY] ]]; then
        git worktree remove --force "$target" && { echo "Done."; _removed=true; } || return 1
      else
        return 1
      fi
    }
  fi

  if [ "$_removed" = true ] && [ -n "$_target_branch" ] \
     && git show-ref --verify --quiet "refs/heads/$_target_branch" 2>/dev/null; then
    local _pr_note=""
    if command -v gh >/dev/null 2>&1; then
      local _merged_pr
      _merged_pr=$(gh pr list --head "$_target_branch" --state merged --json number --jq '.[0].number' 2>/dev/null)
      [ -n "$_merged_pr" ] && _pr_note=" (merged via PR #$_merged_pr)"
    fi
    printf "Also delete branch \"%s\"%s? (enter: yes · esc: no) " "$_target_branch" "$_pr_note"
    local _del
    read -rsk1 _del
    echo ""
    if [[ "$_del" == $'\n' || "$_del" == "" || "$_del" == [yY] ]]; then
      if git branch -d "$_target_branch" 2>/dev/null; then
        echo "Deleted branch \"$_target_branch\"."
      else
        git branch -D "$_target_branch" \
          && echo "Force-deleted branch \"$_target_branch\" (not merged locally)."
      fi
    fi
  fi
}

# Interactive worktree picker
# Args: prompt_text [default_action]
# Sets: _wt_picked_name _wt_picked_action
_wtree_picker() {
  local prompt_text="$1"
  local default_action="${2:-enter}"
  local repo_root
  repo_root=$(_wtree_repo_root) || return 1

  local -a _wt_names=() _wt_lines=()
  while IFS= read -r _line; do
    local _path="${_line%% *}"
    local _name="${_path##*/}"
    [[ "$_path" == "$repo_root" ]] && continue
    _wt_names+=("$_name")
    _wt_lines+=("$_line")
  done < <(git worktree list)

  if [[ ${#_wt_names[@]} -eq 0 ]]; then
    echo "No worktrees. Use 'wtree add <input>' to create one."
    return 1
  fi

  local _sel=0 _total=${#_wt_names[@]} _key
  local _current_wt
  _current_wt=$(git rev-parse --show-toplevel 2>/dev/null)

  # Fetch per-worktree status in parallel. Each query is capped at 1s so a
  # stalled filesystem can't hang the picker.
  local _tmpdir
  _tmpdir=$(mktemp -d 2>/dev/null)
  if [ -n "$_tmpdir" ]; then
    for (( _i=0; _i<_total; _i++ )); do
      local _p="${_wt_lines[$((_i+1))]%% *}"
      (
        local _d=""
        [ -n "$(_wtree_sh_timeout 1 git -C "$_p" status --porcelain 2>/dev/null)" ] && _d="*"
        local _w
        _w=$(_wtree_sh_timeout 1 git -C "$_p" log -1 --format=%cr HEAD 2>/dev/null)
        printf '%s\t%s\n' "$_d" "$_w" > "$_tmpdir/$_i"
      ) &
    done
    wait
  fi

  local -a _wt_display=()
  for (( _i=0; _i<_total; _i++ )); do
    local _full="${_wt_lines[$((_i+1))]}"
    local _path="${_full%% *}"
    local _branch="${_full##*\[}"
    _branch="${_branch%\]*}"
    local _d="" _w=""
    if [ -n "$_tmpdir" ] && [ -f "$_tmpdir/$_i" ]; then
      IFS=$'\t' read -r _d _w < "$_tmpdir/$_i"
    fi
    local _dirty=""
    [ -n "$_d" ] && _dirty=" *"
    local _when=""
    [ -n "$_w" ] && _when=" · $_w"
    local _current=""
    [ -n "$_current_wt" ] && [[ "$_path" == "$_current_wt" ]] && _current=" (current)"
    _wt_display+=("${_wt_names[$((_i+1))]}  (${_branch})${_dirty}${_when}${_current}")
  done

  [ -n "$_tmpdir" ] && rm -rf "$_tmpdir"

  local _term_width="${COLUMNS:-80}"

  _wtree_draw_menu() {
    local i _line_text
    for (( i=0; i<_total; i++ )); do
      if (( i == _sel )); then
        _line_text="  ▸ ${_wt_display[$((i+1))]}"
        printf "\033[7m%-*.*s\033[0m\n" "$_term_width" "$_term_width" "$_line_text"
      else
        _line_text="    ${_wt_display[$((i+1))]}"
        printf "%.*s\n" "$_term_width" "$_line_text"
      fi
    done
  }

  _wtree_clear_menu() {
    printf "\033[%dA\033[J" "$_total"
  }

  echo "$prompt_text"
  _wtree_draw_menu
  _wt_picked_action=""
  _wt_picked_name=""

  while true; do
    read -rsk1 _key
    if [[ "$_key" == $'\e' ]]; then
      read -rsk1 -t 0.01 _key
      if [[ "$_key" == "[" ]]; then
        read -rsk1 -t 0.01 _key
        case "$_key" in
          A) (( _sel > 0 )) && (( _sel-- )) ;;
          B) (( _sel < _total - 1 )) && (( _sel++ )) ;;
        esac
      else
        _wtree_clear_menu
        echo "Cancelled."
        unfunction _wtree_draw_menu _wtree_clear_menu 2>/dev/null
        return 1
      fi
    elif [[ "$_key" == $'\n' ]]; then
      _wt_picked_action="$default_action"
      break
    elif [[ "$_key" == "x" ]]; then
      _wt_picked_action="remove"
      break
    elif [[ "$_key" == "q" ]]; then
      _wtree_clear_menu
      echo "Cancelled."
      unfunction _wtree_draw_menu _wtree_clear_menu 2>/dev/null
      return 1
    elif [[ "$_key" == "j" ]]; then
      (( _sel < _total - 1 )) && (( _sel++ ))
    elif [[ "$_key" == "k" ]]; then
      (( _sel > 0 )) && (( _sel-- ))
    fi
    _wtree_clear_menu
    _wtree_draw_menu
  done

  _wtree_clear_menu
  _wt_picked_name="${_wt_names[$((_sel+1))]}"
  unfunction _wtree_draw_menu _wtree_clear_menu 2>/dev/null
}

_wtree_do_add() {
  local input="$1"
  if [ -z "$input" ]; then
    echo "Usage: wtree <input>" >&2
    echo "  <input> can be: branch name, issue/PR number (#N or N), or GitHub PR/issue URL" >&2
    return 1
  fi

  local repo_root
  repo_root=$(_wtree_repo_root) || return 1

  # Classify input
  local _type="" _num=""
  case "$input" in
    https://github.com/*/pull/[0-9]*)
      _type="pr"
      local _stripped="${input#https://github.com/}"
      local _url_nwo="${_stripped%%/pull/*}"
      local _rest="${_stripped#*/pull/}"
      _num="${_rest%%/*}"
      # Validate repo match
      local _current_nwo
      _current_nwo=$(_wtree_get_nwo) || { echo "Could not determine current repo from origin" >&2; return 1; }
      local _lower_url _lower_current
      _lower_url=$(echo "$_url_nwo" | tr '[:upper:]' '[:lower:]')
      _lower_current=$(echo "$_current_nwo" | tr '[:upper:]' '[:lower:]')
      if [[ "$_lower_url" != "$_lower_current" ]]; then
        echo "Repo mismatch: URL is for $_url_nwo but you're in $_current_nwo" >&2
        return 1
      fi
      ;;
    https://github.com/*/issues/[0-9]*)
      _type="issue"
      local _stripped="${input#https://github.com/}"
      local _url_nwo="${_stripped%%/issues/*}"
      local _rest="${_stripped#*/issues/}"
      _num="${_rest%%/*}"
      # Validate repo match
      local _current_nwo
      _current_nwo=$(_wtree_get_nwo) || { echo "Could not determine current repo from origin" >&2; return 1; }
      local _lower_url _lower_current
      _lower_url=$(echo "$_url_nwo" | tr '[:upper:]' '[:lower:]')
      _lower_current=$(echo "$_current_nwo" | tr '[:upper:]' '[:lower:]')
      if [[ "$_lower_url" != "$_lower_current" ]]; then
        echo "Repo mismatch: URL is for $_url_nwo but you're in $_current_nwo" >&2
        return 1
      fi
      ;;
    *)
      local _stripped_hash="${input#\#}"
      if [[ "$_stripped_hash" =~ ^[0-9]+$ ]]; then
        _type="number"
        _num="$_stripped_hash"
      else
        _type="text"
      fi
      ;;
  esac

  # Resolve to branch, slug, and summary
  local branch="" slug="" summary="" is_existing_branch=false

  case "$_type" in
    pr)
      local _pr_data head_branch pr_title
      _pr_data=$(gh pr view "$_num" --json headRefName,title -q '.headRefName + "\t" + .title') || {
        echo "Failed to fetch PR #$_num" >&2
        return 1
      }
      head_branch="${_pr_data%%	*}"
      pr_title="${_pr_data#*	}"
      branch="$head_branch"
      slug="$(_wtree_sanitize "$head_branch")"
      summary="PR #$_num: $pr_title → branch \"$head_branch\""
      is_existing_branch=true
      ;;
    issue)
      local issue_title
      issue_title=$(gh issue view "$_num" --json title -q .title) || {
        echo "Failed to fetch issue #$_num" >&2
        return 1
      }
      slug="$(_wtree_issue_slug "$_num" "$issue_title")"
      summary="Issue #$_num: $issue_title"
      ;;
    number)
      local _pr_data head_branch pr_title
      if _pr_data=$(gh pr view "$_num" --json headRefName,title -q '.headRefName + "\t" + .title' 2>/dev/null); then
        head_branch="${_pr_data%%	*}"
        pr_title="${_pr_data#*	}"
        branch="$head_branch"
        slug="$(_wtree_sanitize "$head_branch")"
        summary="PR #$_num: $pr_title → branch \"$head_branch\""
        is_existing_branch=true
      else
        local issue_title
        issue_title=$(gh issue view "$_num" --json title -q .title) || {
          echo "#$_num is not a PR or issue in this repo" >&2
          return 1
        }
        slug="$(_wtree_issue_slug "$_num" "$issue_title")"
        summary="Issue #$_num: $issue_title"
      fi
      ;;
    text)
      if git show-ref --verify --quiet "refs/heads/$input" 2>/dev/null; then
        branch="$input"
        slug="$(_wtree_sanitize "$input")"
        summary="Branch \"$input\" (local)"
        is_existing_branch=true
      elif git show-ref --verify --quiet "refs/remotes/origin/$input" 2>/dev/null; then
        branch="$input"
        slug="$(_wtree_sanitize "$input")"
        summary="Branch \"$input\" (remote)"
        is_existing_branch=true
      else
        slug="$(_wtree_sanitize "$input")"
        summary="New branch from \"$input\""
      fi
      ;;
  esac

  # Determine branch name if not already set (issue / new branch cases)
  if [ -z "$branch" ]; then
    if _wtree_is_own_repo; then
      branch="$slug"
    elif [[ "$_type" == "text" && "$input" == */* ]]; then
      branch="$input"
    else
      branch="pierce/$slug"
    fi
  fi

  # If we derived the branch name (issue / new text), the branch itself may
  # already exist even though no worktree references it. Detect that so we
  # check it out instead of trying to re-create it.
  local branch_note=""
  if [ "$is_existing_branch" = false ]; then
    if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
      is_existing_branch=true
      branch_note="branch already exists locally — will check it out"
    elif git show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
      is_existing_branch=true
      branch_note="branch already exists on origin — will check it out"
    fi
  fi

  # Check for existing worktree with this branch
  if _wtree_find_existing "$branch"; then
    echo "Worktree already exists for branch \"$branch\": $_wt_existing_path"
    cd "$_wt_existing_path"
    echo "Now in: $(pwd)"
    return 0
  fi

  # Confirm
  local worktree_path="$repo_root/.worktrees/$slug"
  echo ""
  echo "  Detected: $summary"
  echo "  Worktree: .worktrees/$slug"
  echo "  Branch:   $branch"
  [ -n "$branch_note" ] && echo "  Note:     $branch_note"
  echo ""
  printf "Continue? (enter: yes · esc: no) "
  local _ans
  read -rsk1 _ans
  echo ""
  if [[ "$_ans" != $'\n' && "$_ans" != "" && "$_ans" != [yY] ]]; then
    echo "Cancelled."
    return 1
  fi

  # Create worktree
  _wtree_ensure_gitignore "$repo_root"
  mkdir -p "$repo_root/.worktrees"

  if [ "$is_existing_branch" = true ]; then
    if ! git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
      git fetch origin "$branch" || { echo "Failed to fetch branch \"$branch\" from origin" >&2; return 1; }
    fi
    git worktree add "$worktree_path" "$branch" || return 1
  else
    git worktree add -b "$branch" "$worktree_path" || return 1
  fi

  _wtree_copy_configs "$repo_root" "$worktree_path"
  _wtree_install_deps "$worktree_path"

  echo ""
  echo "Worktree: $worktree_path"
  echo "Branch:   $branch"
  cd "$worktree_path"
  echo "Now in: $(pwd)"
}

case "$cmd" in
  "")
    # Interactive picker — cd or remove
    _wtree_picker "Worktrees (↑/↓ navigate · enter: cd · x: remove · q: quit):" "enter" || return $?
    local _repo_root
    _repo_root=$(_wtree_repo_root) || return 1
    local picked_path="$_repo_root/.worktrees/$_wt_picked_name"

    case "$_wt_picked_action" in
      enter)
        cd "$picked_path"
        echo "Now in: $(pwd)"
        ;;
      remove)
        _wtree_do_remove "$_wt_picked_name"
        ;;
    esac
    ;;

  add)
    shift
    _wtree_do_add "$1"
    ;;

  ls|list)
    git worktree list
    ;;

  rm|remove)
    shift
    local target="" force_flag="--no-force"
    for arg in "$@"; do
      case "$arg" in
        --force) force_flag="--force" ;;
        *) [ -z "$target" ] && target="$arg" ;;
      esac
    done

    if [ -z "$target" ]; then
      local _gitdir _commondir
      _gitdir="$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)"
      _commondir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
      if [[ "$_gitdir" != "$_commondir" ]]; then
        target="$(git rev-parse --show-toplevel 2>/dev/null)"
        echo "Detected worktree: $target"
      else
        _wtree_picker "Select worktree to remove (↑/↓ navigate, enter confirm, q cancel):" "remove" || return $?
        target="$_wt_picked_name"
      fi
    fi

    _wtree_do_remove "$target" "$force_flag"
    ;;

  help)
    echo "Usage: wtree [command] [args]"
    echo ""
    echo "Commands:"
    echo "  (no args)                 Interactive worktree picker (cd/remove)"
    echo "  <input>                   Smart-add worktree from any input:"
    echo "    PR URL                    https://github.com/owner/repo/pull/123"
    echo "    Issue URL                 https://github.com/owner/repo/issues/45"
    echo "    Issue/PR number           42 or #42"
    echo "    Branch name               feature/foo or pierce/my-branch"
    echo "    New name                  my-feature (creates new branch)"
    echo "  add <input>               Same as above (explicit form)"
    echo "  ls                        List all worktrees"
    echo "  rm [name] [--force]       Remove worktree (auto-detects or picker)"
    echo "  help                      Show this help"
    echo ""
    echo "Branches prefixed with pierce/ for repos not owned by McBrideMusings."
    echo "Issue-derived branch slugs are compacted to keep names shorter."
    ;;

  *)
